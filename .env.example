# ═══════════════════════════════════════════════════════════════
#  BE IMPARABLES — Variables de entorno
#  Copia este archivo como ".env" y rellena tus valores reales.
#
#  Credenciales en: https://www.mercadopago.com.co/developers/panel/credentials
#  Usa las credenciales TEST-* para probar, luego cambia a producción.
# ═══════════════════════════════════════════════════════════════

# ── MercadoPago ───────────────────────────────────────────────
# Access Token PRIVADO (solo en el backend, nunca en el frontend)
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# Public Key PÚBLICA (va en el frontend / index.html → variable MP_PUBLIC_KEY)
MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Servidor ──────────────────────────────────────────────────
PORT=3000

# URL pública de tu sitio (importante para back_urls y webhooks)
# En desarrollo: http://localhost:3000
# En producción: https://tudominio.com
BASE_URL=http://localhost:3000

# ── Webhook (opcional) ────────────────────────────────────────
# Si usas ngrok en desarrollo: https://xxxx.ngrok.io/webhook
# En producción: https://tudominio.com/webhook
# Déjalo vacío para usar BASE_URL/webhook automáticamente
WEBHOOK_URL=
